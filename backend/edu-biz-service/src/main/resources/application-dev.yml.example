spring:
  config:
    import: nacos:${spring.application.name}.yml?group=${NACOS_GROUP:DEFAULT_GROUP}&refreshEnabled=true
  flyway:
    locations: classpath:db/migration
  cloud:
    nacos:
      discovery:
        enabled: true
      config:
        enabled: true

# dev 环境不加载 db/localmigration，凭据全部由环境变量或密钥管理系统注入。
