spring:
  config:
    import: nacos:${spring.application.name}.yml?group=${NACOS_GROUP:DEFAULT_GROUP}&refreshEnabled=true
  sql:
    init:
      mode: never
  cloud:
    nacos:
      discovery:
        enabled: true
      config:
        enabled: true

# dev 服务不自动改表；新空库由 online_education_bootstrap.sql 初始化。
# 凭据全部由环境变量或密钥管理系统注入。
