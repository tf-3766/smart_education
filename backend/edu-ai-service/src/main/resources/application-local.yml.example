spring:
  config:
    import: nacos:${spring.application.name}.yml?group=${NACOS_GROUP:DEFAULT_GROUP}&refreshEnabled=true
  cloud:
    nacos:
      discovery:
        enabled: true
      config:
        enabled: true

# 默认 AI_CHAT_PROVIDER=none，问答/摘要接口返回明确的框架模式。
# 启用模型时由环境变量注入 AI_CHAT_PROVIDER=openai 和 OPENAI_API_KEY，不得在本文件写密钥。
