# Copy to backend/.env for local development. Replace every replace-me value.
# Spring Boot does not load .env automatically; dot-source scripts/import-env.ps1 first.

DB_URL=jdbc:mysql://127.0.0.1:3307/edu_biz?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=edu
DB_PASSWORD=replace-me-db-password
MYSQL_ROOT_PASSWORD=replace-me-root-password
MYSQL_PORT=3307

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=edu
RABBITMQ_PASSWORD=replace-me-rabbitmq-password

NACOS_ENABLED=true
NACOS_CONFIG_ENABLED=true
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=
NACOS_PASSWORD=

JWT_SECRET=replace-me-with-a-random-secret-at-least-32-bytes-long
JWT_TTL=PT2H
JWT_ISSUER=edu-biz-service

GATEWAY_SERVER_PORT=18080
BIZ_SERVER_PORT=18081
AI_SERVER_PORT=18082
CORS_ALLOWED_ORIGINS=http://localhost:5173
AI_RATE_REPLENISH=5
AI_RATE_BURST=10

# AI_PROVIDER / MODEL_API_KEY / VECTOR_STORE_* are intentionally absent in phase 1.
