# Copy to backend/.env for local development. Replace every replace-me value.
# Spring Boot does not load .env automatically; dot-source scripts/import-env.ps1 first.

DB_URL=jdbc:mysql://127.0.0.1:3307/smart_education?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=123456
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3307

REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=smart_education
RABBITMQ_PASSWORD=123456

NACOS_ENABLED=true
NACOS_CONFIG_ENABLED=true
NACOS_SERVER_ADDR=127.0.0.1:18848
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=
NACOS_PASSWORD=

JWT_SECRET=replace-me-with-a-random-secret-at-least-32-bytes-long
JWT_TTL=PT2H
JWT_ISSUER=edu-biz-service

GATEWAY_SERVER_PORT=18080
BIZ_SERVER_PORT=18081
AI_SERVER_PORT=18082
CORS_ALLOWED_ORIGINS=http://localhost:5173
FILE_STORAGE_ROOT=./data/uploads
FILE_MAX_SIZE=50MB
FILE_MAX_REQUEST_SIZE=52MB
AI_RATE_REPLENISH=5
AI_RATE_BURST=10

# Spring AI is disabled by default so the stack can start without an external model.
AI_CHAT_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4.1-mini
AI_TEMPERATURE=0.2

# Reserved for the next Spring AI vector-store slice; current service does not create a Qdrant collection.
QDRANT_REST_URL=http://127.0.0.1:16333
